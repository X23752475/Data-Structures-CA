        }
    }                                          

    private void addBtnActionPerformed(java.awt.event.ActionEvent evt) {                                       
        // TODO add your handling code here:
        
    String id = iDTxt.getText().trim();
    String location = locationTxt.getText().trim();
    String batteryStr = batteryTxt.getText().trim();
    boolean available = availableBox.isSelected();

    
    if (id.isEmpty() || location.isEmpty() || batteryStr.isEmpty()) {
        javax.swing.JOptionPane.showMessageDialog(this, "All fields must be filled");
        return;
    }

    
    if (!batteryStr.matches("\\d+")) {
        javax.swing.JOptionPane.showMessageDialog(this, "Battery must be a number");
        return;
    }

    
    int battery = Integer.parseInt(batteryStr);

    
    if (battery < 0 || battery > 100) {
        javax.swing.JOptionPane.showMessageDialog(this, "Battery must be between 0 and 100");
        return;
    }

    MobilityDevice device;

    
    if (bikeBox.isSelected()) {
        device = new eBike(id, location, battery, available, 25);
    } 
    else if (scooterBox.isSelected()) {
        device = new Scooter(id, location, battery, available, 20);
    } 
    else {
        javax.swing.JOptionPane.showMessageDialog(this, "Select a device type");
        return;
    }

    
    devices.add(device);

    
    undoStack.push("ADD:" + id);

    
    if (battery < 20) {
        chargingQueue.enqueue(device);
    }

    
    javax.swing.JOptionPane.showMessageDialog(this, "Device Added Successfully!");

    
    iDTxt.setText("");
    locationTxt.setText("");
    batteryTxt.setText("");
    bikeBox.setSelected(false);
    scooterBox.setSelected(false);
    availableBox.setSelected(false);
    }                                      

